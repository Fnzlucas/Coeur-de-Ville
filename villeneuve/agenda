<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Agenda — Cœur de Ville</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
  :root {
    --bg: #F1F2F4;
    --surface: #FFFFFF;
    --ink: #0A0A0A;
    --ink-soft: #4A4A4A;
    --ink-muted: #8A8A8A;
    --line: #E4E6EA;
    --accent: #2563EB;
    --orange: #FF6B2C;
    --green: #10B981;
  }
  html, body {
    background: var(--bg); color: var(--ink);
    font-family: 'Plus Jakarta Sans', -apple-system, sans-serif;
    font-weight: 500; -webkit-font-smoothing: antialiased; overflow-x: hidden;
  }
  body { padding-bottom: 110px; }

  .top-header {
    position: sticky; top: 0; z-index: 100; background: var(--bg);
    padding: 14px 20px;
    display: grid; grid-template-columns: 40px 1fr 40px; align-items: center;
  }
  .icon-btn {
    width: 40px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    background: none; border: none; color: var(--ink); cursor: pointer; border-radius: 50%;
  }
  .icon-btn svg { width: 22px; height: 22px; }
  .logo {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    font-size: 18px; font-weight: 700; letter-spacing: -0.01em;
  }
  .logo-heart { width: 22px; height: 22px; color: var(--ink); }

  .hero { padding: 24px 20px 24px; }
  .hero-eyebrow { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
  .eyebrow-line { width: 24px; height: 2px; background: var(--orange); }
  .eyebrow-text {
    font-size: 12px; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--orange);
  }
  .hero-title {
    font-size: 34px; font-weight: 800; line-height: 1.1;
    letter-spacing: -0.02em; color: var(--ink);
  }

  .month-bar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 20px 16px;
  }
  .month-bar button {
    width: 40px; height: 40px;
    background: var(--surface); border: 1px solid var(--line); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; color: var(--ink);
  }
  .month-bar button svg { width: 18px; height: 18px; }
  .month-display { font-size: 18px; font-weight: 700; letter-spacing: -0.01em; }

  .mini-cal {
    background: var(--surface); margin: 0 20px 24px;
    padding: 18px 16px; border-radius: 20px;
  }
  .mini-cal-header {
    display: grid; grid-template-columns: repeat(7, 1fr); margin-bottom: 10px;
  }
  .mini-cal-header span {
    text-align: center; font-size: 11px; font-weight: 700;
    color: var(--ink-muted); letter-spacing: 0.05em; text-transform: uppercase;
  }
  .mini-cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; }
  .cal-day {
    aspect-ratio: 1; display: flex; align-items: center; justify-content: center;
    font-size: 14px; font-weight: 600; color: var(--ink);
    border-radius: 12px; cursor: pointer; position: relative; transition: all 0.15s;
  }
  .cal-day:hover { background: var(--bg); }
  .cal-day.has-event::after {
    content: ''; width: 4px; height: 4px; background: var(--accent);
    border-radius: 50%; position: absolute; bottom: 5px;
  }
  .cal-day.active { background: var(--accent); color: #fff; }
  .cal-day.active.has-event::after { background: #fff; }
  .cal-day.muted { color: var(--ink-muted); opacity: 0.35; }

  .section-head {
    padding: 8px 20px 14px;
    display: flex; align-items: baseline; justify-content: space-between;
  }
  .section-eyebrow { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
  .section-eyebrow .line { width: 20px; height: 2px; background: var(--orange); }
  .section-eyebrow span {
    font-size: 11px; font-weight: 700; color: var(--orange);
    letter-spacing: 0.1em; text-transform: uppercase;
  }
  .section-title { font-size: 22px; font-weight: 800; letter-spacing: -0.01em; }

  .filters { padding: 0 20px 16px; overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
  .filters::-webkit-scrollbar { display: none; }
  .filters-row { display: flex; gap: 8px; width: max-content; }
  .filter-chip {
    background: var(--surface); border: 1px solid var(--line); color: var(--ink);
    padding: 10px 18px; border-radius: 100px;
    font-size: 13px; font-weight: 600; font-family: inherit;
    cursor: pointer; white-space: nowrap; transition: all 0.2s;
  }
  .filter-chip.active { background: var(--ink); color: #fff; border-color: var(--ink); }

  .featured-section { padding: 0 20px 28px; }
  .featured-card {
    border-radius: 24px; overflow: hidden; position: relative;
    height: 280px; background: linear-gradient(135deg, #4A5D4E 0%, #1F2A21 100%);
    display: flex; align-items: flex-end; padding: 20px; color: #fff; cursor: pointer;
  }
  .featured-card::before {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.78) 0%, transparent 55%);
  }
  .featured-content { position: relative; z-index: 2; width: 100%; }
  .featured-tag {
    display: inline-flex; align-items: center; gap: 5px;
    background: var(--orange); color: #fff;
    font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    padding: 6px 11px; border-radius: 6px; margin-bottom: 14px;
  }
  .featured-title {
    font-size: 26px; font-weight: 800; line-height: 1.15;
    margin-bottom: 8px; letter-spacing: -0.015em;
  }
  .featured-meta {
    display: flex; align-items: center; gap: 8px;
    font-size: 13px; font-weight: 500; opacity: 0.95;
  }
  .featured-meta .dot { opacity: 0.5; }

  .timeline { padding: 0 20px 32px; }
  .day-group { margin-bottom: 28px; }
  .day-header { display: flex; align-items: center; gap: 14px; margin-bottom: 14px; }
  .day-number-box {
    width: 56px; height: 56px;
    background: var(--surface); border-radius: 16px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .day-number { font-size: 22px; font-weight: 800; line-height: 1; letter-spacing: -0.02em; }
  .day-month-mini {
    font-size: 9px; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--ink-muted); margin-top: 2px;
  }
  .day-info { display: flex; flex-direction: column; gap: 2px; flex: 1; }
  .day-name { font-size: 16px; font-weight: 700; letter-spacing: -0.01em; }
  .day-count { font-size: 12px; font-weight: 500; color: var(--ink-muted); }
  .day-badge {
    background: var(--orange); color: #fff;
    font-size: 10px; font-weight: 700; padding: 4px 10px;
    border-radius: 100px; letter-spacing: 0.04em; text-transform: uppercase;
  }

  .event-card {
    background: var(--surface); border-radius: 20px; overflow: hidden;
    margin-bottom: 12px; cursor: pointer; transition: transform 0.15s ease;
  }
  .event-card:active { transform: scale(0.98); }
  .event-img {
    width: 100%; height: 180px;
    background: linear-gradient(135deg, #D4C5A9 0%, #8B7355 100%);
    position: relative; overflow: hidden;
  }
  .event-img.img-2 { background: linear-gradient(135deg, #6B7B6E 0%, #2C3E2D 100%); }
  .event-img.img-3 { background: linear-gradient(135deg, #C9A961 0%, #8B6F2C 100%); }
  .event-img.img-4 { background: linear-gradient(135deg, #A89B82 0%, #5C5346 100%); }
  .event-img.img-5 { background: linear-gradient(135deg, #B8927A 0%, #6B4226 100%); }
  .event-tag {
    position: absolute; top: 14px; left: 14px;
    background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);
    color: var(--ink);
    font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    padding: 6px 10px; border-radius: 8px;
  }
  .event-time-badge {
    position: absolute; top: 14px; right: 14px;
    background: var(--ink); color: #fff;
    font-size: 12px; font-weight: 700;
    padding: 6px 12px; border-radius: 8px;
  }
  .event-body { padding: 16px 18px 18px; }
  .event-title {
    font-size: 17px; font-weight: 700; line-height: 1.3;
    letter-spacing: -0.01em; margin-bottom: 8px;
  }
  .event-place {
    font-size: 13px; color: var(--ink-muted); font-weight: 500;
    display: flex; align-items: center; gap: 5px; margin-bottom: 14px;
  }
  .event-place svg { width: 13px; height: 13px; flex-shrink: 0; }
  .event-footer {
    display: flex; align-items: center; justify-content: space-between;
    padding-top: 14px; border-top: 1px solid var(--line);
  }
  .event-price { font-size: 14px; font-weight: 700; color: var(--ink); }
  .event-price.free { color: var(--green); }
  .event-cta {
    background: var(--accent); color: #fff; border: none; font-family: inherit;
    font-size: 13px; font-weight: 700;
    padding: 9px 16px; border-radius: 100px; cursor: pointer;
    display: flex; align-items: center; gap: 5px;
  }
  .event-cta svg { width: 14px; height: 14px; }

  .bottom-nav {
    position: fixed; bottom: 16px; left: 16px; right: 16px; z-index: 100;
    background: var(--surface); border-radius: 100px; padding: 10px 8px;
    display: grid; grid-template-columns: repeat(4, 1fr);
    box-shadow: 0 8px 32px rgba(0,0,0,0.08), 0 1px 3px rgba(0,0,0,0.04);
  }
  .nav-item {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 3px; padding: 6px 4px;
    color: var(--ink-muted); text-decoration: none;
    font-size: 10px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav-item.active { color: var(--accent); }
  .nav-item svg { width: 22px; height: 22px; }
</style>
</head>
