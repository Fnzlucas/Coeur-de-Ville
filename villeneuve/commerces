<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
  :root {
    --bg: #F1F2F4;
    --surface: #FFFFFF;
    --ink: #0A0A0A;
    --ink-soft: #4A4A4A;
    --ink-muted: #8A8A8A;
    --line: #E4E6EA;
    --accent: #2563EB;
    --orange: #FF6B2C;
    --green: #10B981;
  }
  html, body {
    background: var(--bg); color: var(--ink);
    font-family: 'Plus Jakarta Sans', -apple-system, sans-serif;
    font-weight: 500; -webkit-font-smoothing: antialiased; overflow-x: hidden;
  }
  body { padding-bottom: 110px; }

  .top-header {
    position: sticky; top: 0; z-index: 100; background: var(--bg);
    padding: 14px 20px;
    display: grid; grid-template-columns: 40px 1fr 40px; align-items: center;
  }
  .icon-btn {
    width: 40px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    background: none; border: none; color: var(--ink); cursor: pointer; border-radius: 50%;
  }
  .icon-btn svg { width: 22px; height: 22px; }
  .logo {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    font-size: 18px; font-weight: 700; letter-spacing: -0.01em;
  }
  .logo-heart { width: 22px; height: 22px; color: var(--ink); }

  .hero { padding: 24px 20px 20px; }
  .hero-eyebrow { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
  .eyebrow-line { width: 24px; height: 2px; background: var(--orange); }
  .eyebrow-text {
    font-size: 12px; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--orange);
  }
  .hero-title {
    font-size: 34px; font-weight: 800; line-height: 1.1;
    letter-spacing: -0.02em; color: var(--ink);
  }

  .search-wrap { padding: 8px 20px 24px; }
  .search {
    display: flex; align-items: center; background: var(--surface);
    border-radius: 16px; padding: 0 18px; height: 52px;
  }
  .search svg { width: 20px; height: 20px; color: var(--ink-muted); margin-right: 12px; }
  .search input {
    border: none; background: none; flex: 1;
    font-family: inherit; font-size: 15px; font-weight: 500; color: var(--ink); outline: none;
  }
  .search input::placeholder { color: var(--ink-muted); font-weight: 500; }

  .section-head {
    padding: 8px 20px 14px;
    display: flex; align-items: baseline; justify-content: space-between;
  }
  .section-eyebrow { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
  .section-eyebrow .line { width: 20px; height: 2px; background: var(--orange); }
  .section-eyebrow span {
    font-size: 11px; font-weight: 700; color: var(--orange);
    letter-spacing: 0.1em; text-transform: uppercase;
  }
  .section-title { font-size: 22px; font-weight: 800; letter-spacing: -0.01em; }
  .section-link {
    font-size: 14px; color: var(--accent); font-weight: 700; text-decoration: none;
  }

  .cat-grid {
    padding: 0 20px 24px;
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px;
  }
  .cat-tile {
    background: var(--surface); border-radius: 18px;
    padding: 16px 8px 14px;
    text-align: center; cursor: pointer; transition: all 0.2s;
    text-decoration: none; color: var(--ink);
    display: flex; flex-direction: column; align-items: center; gap: 8px;
  }
  .cat-tile:active { transform: scale(0.96); }
  .cat-tile.active { background: var(--ink); color: #fff; }
  .cat-icon {
    width: 40px; height: 40px; border-radius: 12px;
    background: var(--bg);
    display: flex; align-items: center; justify-content: center;
    color: var(--ink); transition: all 0.2s;
  }
  .cat-tile.active .cat-icon { background: rgba(255,255,255,0.15); color: #fff; }
  .cat-icon svg { width: 20px; height: 20px; }
  .cat-name { font-size: 11px; font-weight: 700; line-height: 1.2; }
  .cat-count { font-size: 10px; color: var(--ink-muted); font-weight: 600; }
  .cat-tile.active .cat-count { color: rgba(255,255,255,0.7); }

  .featured-section { padding: 0 20px 28px; }
  .featured-card {
    border-radius: 24px; overflow: hidden; position: relative;
    height: 280px; background: linear-gradient(135deg, #8B6F2C 0%, #4A3B1B 100%);
    display: flex; align-items: flex-end; padding: 20px; color: #fff; cursor: pointer;
  }
  .featured-card::before {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.78) 0%, transparent 55%);
  }
  .featured-status {
    position: absolute; top: 16px; right: 16px;
    background: var(--green); color: #fff;
    font-size: 11px; font-weight: 700; padding: 6px 11px; border-radius: 100px;
    display: flex; align-items: center; gap: 5px;
    z-index: 3;
  }
  .featured-status::before {
    content: ''; width: 6px; height: 6px; background: #fff; border-radius: 50%;
  }
  .featured-content { position: relative; z-index: 2; width: 100%; }
  .featured-tag {
    display: inline-flex; align-items: center; gap: 5px;
    background: var(--orange); color: #fff;
    font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    padding: 6px 11px; border-radius: 6px; margin-bottom: 14px;
  }
  .featured-cat {
    font-size: 11px; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; opacity: 0.85; margin-bottom: 6px;
  }
  .featured-title {
    font-size: 26px; font-weight: 800; line-height: 1.15;
    margin-bottom: 8px; letter-spacing: -0.015em;
  }
  .featured-meta {
    display: flex; align-items: center; gap: 10px;
    font-size: 13px; font-weight: 500;
  }
  .featured-meta .star { color: #FCD34D; }
  .featured-meta svg { width: 14px; height: 14px; }
  .featured-meta .stat { display: flex; align-items: center; gap: 4px; }

  .tab-bar {
    display: flex; gap: 0; padding: 0 20px;
    border-bottom: 1px solid var(--line);
    margin-bottom: 16px;
    overflow-x: auto; scrollbar-width: none;
  }
  .tab-bar::-webkit-scrollbar { display: none; }
  .tab {
    background: none; border: none; padding: 14px 4px;
    margin-right: 24px;
    font-family: inherit; font-size: 14px; font-weight: 600;
    color: var(--ink-muted); cursor: pointer; position: relative; white-space: nowrap;
  }
  .tab.active { color: var(--ink); font-weight: 700; }
  .tab.active::after {
    content: ''; position: absolute; bottom: -1px; left: 0; right: 0;
    height: 2px; background: var(--ink);
  }

  .commerces-section { padding: 0 20px 32px; }
  .commerce-card {
    background: var(--surface); border-radius: 18px;
    overflow: hidden; margin-bottom: 12px;
    cursor: pointer; transition: transform 0.15s ease;
    display: flex;
  }
  .commerce-card:active { transform: scale(0.98); }
  .commerce-img {
    width: 110px; flex-shrink: 0;
    background: linear-gradient(135deg, #D4C5A9 0%, #8B7355 100%);
    position: relative;
  }
  .commerce-img.img-2 { background: linear-gradient(135deg, #B8927A 0%, #6B4226 100%); }
  .commerce-img.img-3 { background: linear-gradient(135deg, #6B7B6E 0%, #2C3E2D 100%); }
  .commerce-img.img-4 { background: linear-gradient(135deg, #C9A961 0%, #8B6F2C 100%); }
  .commerce-img.img-5 { background: linear-gradient(135deg, #A89B82 0%, #5C5346 100%); }
  .commerce-img.img-6 { background: linear-gradient(135deg, #8B6F2C 0%, #4A3B1B 100%); }

  .commerce-status {
    position: absolute; top: 8px; left: 8px;
    background: var(--green); color: #fff;
    font-size: 10px; font-weight: 700;
    padding: 4px 8px; border-radius: 100px;
    display: flex; align-items: center; gap: 4px;
  }
  .commerce-status::before {
    content: ''; width: 5px; height: 5px; background: #fff; border-radius: 50%;
  }
  .commerce-status.closed { background: var(--ink-muted); }

  .commerce-body {
    flex: 1; padding: 14px 16px;
    display: flex; flex-direction: column; justify-content: space-between;
    min-width: 0;
  }
  .commerce-cat {
    font-size: 10px; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--orange); margin-bottom: 4px;
  }
  .commerce-name {
    font-size: 16px; font-weight: 700; line-height: 1.2;
    letter-spacing: -0.01em; margin-bottom: 4px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .commerce-desc {
    font-size: 12px; color: var(--ink-muted); font-weight: 500; line-height: 1.4;
    margin-bottom: 8px;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .commerce-meta {
    display: flex; align-items: center; gap: 10px;
    font-size: 11px; color: var(--ink-muted); font-weight: 600;
  }
  .commerce-rating {
    color: var(--ink); font-weight: 700;
    display: flex; align-items: center; gap: 3px;
  }
  .commerce-rating svg { width: 11px; height: 11px; color: #FCD34D; }

  .bottom-nav {
    position: fixed; bottom: 16px; left: 16px; right: 16px; z-index: 100;
    background: var(--surface); border-radius: 100px; padding: 10px 8px;
    display: grid; grid-template-columns: repeat(4, 1fr);
    box-shadow: 0 8px 32px rgba(0,0,0,0.08), 0 1px 3px rgba(0,0,0,0.04);
  }
  .nav-item {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 3px; padding: 6px 4px;
    color: var(--ink-muted); text-decoration: none;
    font-size: 10px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav-item.active { color: var(--accent); }
  .nav-item svg { width: 22px; height: 22px; }
</style>
</head>
